# =============================
# Cross-channel STT (required)
# =============================
# Sherpa-ONNX offline ASR model dir.
# Must contain tokens.txt and one of: model.int8.onnx / model.onnx / model.fp32.onnx
SHERPA_ONNX_MODEL_DIR=./models/sherpa/sherpa-onnx-paraformer-zh-small-2024-03-09

# Optional: delete inbound input audio after successful STT
# Default: 1 (enabled)
STT_DELETE_INPUT_ON_SUCCESS=1
# Only delete inputs under this directory (best-effort)
OPENCLAW_INBOUND_DIR=/root/.openclaw/media/inbound

# =============================
# Feishu send adapter (optional)
# Only needed if you want to send Feishu native voice bubbles (msg_type=audio)
# =============================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=https://open.feishu.cn

# Piper TTS (optional; only needed for text->voice in Feishu sender)
PIPER_BIN=
PIPER_VOICE=./models/piper/zh_CN-huayan-x_low.onnx
PIPER_VOICE_CONFIG=./models/piper/zh_CN-huayan-x_low.onnx.json

# Playback UX tweak (Feishu sender)
FEISHU_VOICE_LEADING_SILENCE_MS=800

# Temp cleanup policy (Feishu sender)
FEISHU_VOICE_TMP_DIR=./tmp/feishu_voice_io
FEISHU_VOICE_FAIL_TTL_SECONDS=1800
